# ===========================================
# EpisodeX Configuration
# ===========================================

# Path to TV shows folder on host (mounted to /media in Docker)
MEDIA_PATH_HOST=/Volumes/Plex/TV Show

# TVDB API key (get one at https://thetvdb.com/api-information)
TVDB_API_KEY=your_api_key_here

# Server
PORT=8080
HOST=0.0.0.0

# Backups
BACKUP_RETENTION=10
BACKUP_HOUR=3

# Scanning
SCAN_INTERVAL_HOURS=1
TVDB_CHECK_HOUR=5

# qBittorrent integration (optional)
QBIT_URL=http://192.168.1.100:8080
QBIT_USER=admin
QBIT_PASSWORD=secret

# Kinozal tracker integration (optional)
# Enables automatic redownload of updated torrents when new episodes appear
KINOZAL_USER=your_kinozal_username
KINOZAL_PASSWORD=your_kinozal_password

# How often to check tracker for new episodes (default: 6)
TRACKER_CHECK_INTERVAL_HOURS=6
